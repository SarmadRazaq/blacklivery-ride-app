# ===========================================
# BlackLivery Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example: CORS_ORIGINS=https://app.blacklivery.com,https://admin.blacklivery.com
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ─── Firebase ─────────────────────────────────────────────
GCLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./your-firebase-adminsdk.json
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# ─── Auth / Cron ──────────────────────────────────────────
ADMIN_EMAIL=admin@blacklivery.com
CRON_SECRET=generate-a-strong-random-secret-here
DISABLE_CRON=false
PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/reset-password

# ─── Email (SendGrid) ────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@blacklivery.com
SENDGRID_FROM_NAME=BlackLivery

# ─── SMS — Nigeria (Termii) ──────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=BlackLivery

# ─── SMS — USA (Twilio) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Payment: Stripe (USA USD) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_CONNECT_CLIENT_ID=acct_xxxx
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxxx

# ─── Payment: Paystack (Nigeria NGN) ─────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
PAYSTACK_CALLBACK_URL=http://localhost:5000/api/payments/paystack/callback

# ─── Payment: Flutterwave (Nigeria NGN fallback) ─────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxx
FLUTTERWAVE_HASH_SECRET=your-flw-hash-secret
FLUTTERWAVE_CALLBACK_URL=http://localhost:5000/api/payments/flutterwave/callback

# ─── Payment: Monnify (Nigeria NGN alternative) ──────────
MONNIFY_API_KEY=MK_TEST_xxxx
MONNIFY_API_SECRET=xxxx
MONNIFY_WEBHOOK_SECRET=your-monnify-webhook-secret
MONNIFY_CONTRACT_CODE=xxxx
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_CALLBACK_URL=http://localhost:5000/api/payments/monnify/callback
MONNIFY_WALLET_ACCOUNT_NUMBER=xxxx

# ─── Google Maps ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Weather (OpenWeather for surge & driver incentives) ──
OPENWEATHER_API_KEY=your-openweather-api-key
