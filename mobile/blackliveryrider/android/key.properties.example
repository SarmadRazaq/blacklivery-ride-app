# Release Keystore Configuration
# Generate a keystore: keytool -genkey -v -keystore blacklivery-rider.jks -keyalg RSA -keysize 2048 -validity 10000 -alias blacklivery-rider
# DO NOT commit this file to version control.

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=blacklivery-rider
storeFile=../keystore/blacklivery-rider.jks
