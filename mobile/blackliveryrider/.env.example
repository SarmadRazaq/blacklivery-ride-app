# BlackLivery Rider App - Environment Variables
# Copy this file to .env and fill in the values

# Backend API URL (required)
# For Android emulator use: http://10.0.2.2:5000
# For iOS simulator use: http://localhost:5000
# For physical device use your machine's LAN IP: http://192.168.x.x:5000
# For production: https://your-api-domain.com
API_BASE_URL=http://10.0.2.2:5000

# Default region for pricing
DEFAULT_REGION=nigeria

# Password reset redirect URL
PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset

# Google Maps API Key (required for maps functionality)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
